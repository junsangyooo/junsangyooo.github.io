---
import '../../styles/tokens.css'; // shared design tokens (single source of truth)
import { site } from '../../config/site';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Console — Junsang Yoo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      /* is:global so styles also match elements created at runtime by the inline script
         (list rows, tag chips, link rows) and by cursor.ts — Astro would otherwise scope
         these selectors and they'd never match the dynamic DOM. Safe: the console is a
         standalone HTML page, so nothing leaks to the rest of the site. */
      /* design tokens come from the shared tokens.css (imported above) */
      *{box-sizing:border-box;}
      body{margin:0;background:var(--bg);color:var(--fg);font-family:var(--font);-webkit-font-smoothing:antialiased;line-height:1.5;}
      .wrap{width:min(860px,92vw);margin-inline:auto;}
      .mono{font-family:var(--mono);} .hidden{display:none!important;} .dim{color:var(--soft);}
      /* ink cursor — same signature as the main site (cursor.ts builds the DOM) */
      .cursor{position:fixed;top:0;left:0;z-index:9999;pointer-events:none;will-change:transform;transition:opacity .25s var(--ease);}
      .cursor.is-out{opacity:0;}
      .cursor__dot{position:absolute;top:0;left:0;width:14px;height:14px;margin:-7px 0 0 -7px;background:var(--fg);border-radius:50%;transition:width .4s var(--ease),height .4s var(--ease),margin .4s var(--ease),opacity .25s var(--ease);}
      .cursor__label{position:absolute;top:0;left:0;color:var(--white);font:600 12px/1 var(--font);letter-spacing:-.01em;white-space:nowrap;opacity:0;transition:opacity .3s var(--ease);}
      .cursor.is-hover .cursor__dot{width:76px;height:76px;margin:-38px 0 0 -38px;}
      .cursor.is-hover .cursor__label{opacity:1;}
      @media (hover:none),(pointer:coarse){.cursor{display:none;}}
      .btn{position:relative;overflow:hidden;isolation:isolate;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;gap:8px;border:1px solid var(--fg);border-radius:999px;padding:12px 22px;font:600 14px/1 var(--font);color:var(--fg);background:transparent;transition:color .5s var(--ease);}
      .btn::before{content:'';position:absolute;left:50%;bottom:0;z-index:-1;width:150%;aspect-ratio:1/1;background:var(--fg);border-radius:50%;transform:translate(-50%,100%);transition:transform 1s cubic-bezier(.16,1,.3,1);}
      .btn:hover{color:#fff;} .btn:hover::before{transform:translate(-50%,50%);}
      .btn:disabled{opacity:.4;cursor:default;} .btn:disabled::before{transform:translate(-50%,100%);}
      .btn--sm{padding:9px 16px;font-size:13px;} .btn--ghost{border-color:var(--line);} .btn--ghost::before{background:var(--fg);}
      .msg{font:500 13px/1.4 var(--font);color:#c0392b;min-height:18px;} .msg.ok{color:var(--accent);}
      .login{min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;text-align:center;padding:40px 0;}
      .login__kicker{font:500 12px/1 var(--mono);letter-spacing:.2em;text-transform:uppercase;color:var(--soft);}
      .login h1{font-weight:600;letter-spacing:-.03em;font-size:clamp(34px,6vw,54px);margin:0;}
      .login form{display:flex;gap:10px;} .login input{font:500 16px/1 var(--font);padding:14px 18px;border:1px solid var(--line);border-radius:999px;outline:none;width:240px;} .login input:focus{border-color:var(--fg);}
      .head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;padding:clamp(48px,8vh,90px) 0 8px;flex-wrap:wrap;}
      .head h1{font-weight:600;letter-spacing:-.035em;font-size:clamp(38px,6vw,68px);line-height:1;margin:0;}
      .head .tools{display:flex;align-items:center;gap:12px;padding-top:10px;}
      .logout{font:500 13px/1 var(--mono);color:var(--soft);background:none;border:none;cursor:pointer;letter-spacing:.04em;} .logout:hover{color:var(--fg);}
      .lead{color:var(--soft);font:500 15px/1.5 var(--font);max-width:60ch;margin:0 0 28px;}
      .lead code{font:500 13px/1 var(--mono);background:var(--line);padding:2px 6px;border-radius:5px;}
      .rows{display:flex;flex-direction:column;gap:14px;padding-bottom:40px;}
      .row{display:grid;grid-template-columns:72px 1fr auto;gap:18px;align-items:center;border:1px solid var(--line);border-radius:16px;padding:14px 16px;background:var(--bg);transition:border-color .3s var(--ease),transform .3s var(--ease),box-shadow .3s var(--ease);}
      .row:hover{border-color:var(--fg);transform:translateY(-2px);box-shadow:0 16px 34px -20px rgba(0,0,0,.35);}
      .row.pending{border-color:var(--accent);}
      .row__thumb{width:72px;height:72px;border-radius:12px;overflow:hidden;background:var(--line);flex:none;}
      .row__thumb img{width:100%;height:100%;object-fit:cover;display:block;transition:opacity .3s var(--ease);}
      .row__title{font:600 17px/1.2 var(--font);letter-spacing:-.012em;}
      .row__meta{display:flex;flex-wrap:wrap;align-items:center;gap:7px;margin-top:9px;}
      .row__chip{font:500 10px/1 var(--mono);letter-spacing:.06em;text-transform:uppercase;color:var(--fg);border:1px solid var(--line);border-radius:999px;padding:4px 9px;}
      .row__sub{font:500 10px/1 var(--mono);letter-spacing:.08em;text-transform:uppercase;color:var(--soft);}
      .row__sub.is-pending{color:var(--accent);}
      .row__acts{display:flex;align-items:center;gap:7px;}
      .iconbtn{width:38px;height:38px;border:1px solid var(--line);border-radius:50%;background:var(--bg);cursor:pointer;font:600 14px/1 var(--font);color:var(--fg);display:grid;place-items:center;transition:border-color .25s,color .25s,background .25s;}
      .iconbtn:hover{border-color:var(--fg);} .iconbtn:disabled{opacity:.25;cursor:default;}
      .iconbtn--text{width:auto;border-radius:999px;padding:0 17px;font-size:13px;}
      .iconbtn.del:hover{border-color:#c0392b;color:#c0392b;}
      .deploybar{position:sticky;bottom:0;background:color-mix(in srgb,var(--bg) 88%,transparent);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-top:1px solid var(--line);padding:16px 0;display:flex;align-items:center;justify-content:flex-end;gap:14px;}
      .panel{padding:34px 0 120px;}
      .panel__head{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;}
      .panel__head h1{font-weight:600;letter-spacing:-.03em;font-size:clamp(24px,4vw,36px);margin:0;}
      .field{margin-bottom:20px;}
      .field>label{display:block;font:500 11px/1 var(--mono);letter-spacing:.12em;text-transform:uppercase;color:var(--soft);margin-bottom:8px;}
      .field input[type=text],.field input[type=number],.field input[type=url],.field select,.field textarea{width:100%;font:400 15px/1.5 var(--font);padding:11px 13px;border:1px solid var(--line);border-radius:10px;outline:none;background:#fff;color:var(--fg);}
      .field input:disabled{background:#f6f6f6;color:var(--soft);} .field :focus{border-color:var(--fg);}
      .field textarea{min-height:240px;resize:vertical;font-family:var(--mono);font-size:14px;}
      .grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
      .check{display:flex;align-items:center;gap:10px;} .check input{width:18px;height:18px;}
      .drop{border:1px dashed var(--line);border-radius:12px;padding:16px;display:flex;align-items:center;gap:16px;cursor:pointer;} .drop:hover{border-color:var(--fg);}
      .drop img{width:80px;height:80px;object-fit:cover;border-radius:8px;background:var(--line);}
      .tags{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px;}
      .tags:empty{margin-bottom:0;}
      .tag{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--fg);border-radius:999px;padding:5px 6px 5px 12px;font:500 13px/1 var(--font);}
      .tag__x{border:none;background:none;cursor:pointer;color:var(--soft);font:600 13px/1 var(--font);padding:2px 4px;border-radius:50%;}
      .tag__x:hover{color:#c0392b;}
      .linkrow{display:grid;grid-template-columns:1fr 1.4fr auto;gap:10px;margin-bottom:10px;}
      .linkrow input{font:400 14px/1.4 var(--font);padding:10px 12px;border:1px solid var(--line);border-radius:9px;outline:none;} .linkrow input:focus{border-color:var(--fg);}
      .actions{display:flex;align-items:center;gap:14px;margin-top:30px;}
      .pv{padding:34px 0 100px;}
      .pv__card{width:min(420px,80%);} .pv__media{width:100%;aspect-ratio:1/1;border-radius:18px;overflow:hidden;background:var(--line);} .pv__media img{width:100%;height:100%;object-fit:cover;}
      .pv__cap{font:500 22px/1.35 var(--font);letter-spacing:-.015em;margin-top:18px;} .pv__cap b{font-weight:700;}
      .pv__meta{font:500 12px/1 var(--mono);letter-spacing:.05em;text-transform:uppercase;color:var(--soft);margin-top:10px;}
      .pv__hr{height:1px;background:var(--line);margin:46px 0;}
      .pv__kicker{font:500 12px/1 var(--mono);letter-spacing:.16em;text-transform:uppercase;color:var(--soft);}
      .pv__title{font-weight:600;letter-spacing:-.035em;line-height:.95;font-size:clamp(40px,7vw,72px);margin:12px 0 0;}
      .pv__tag{font:500 clamp(18px,2.2vw,24px)/1.3 var(--font);margin-top:14px;max-width:36ch;}
      .pv__btns{display:flex;gap:10px;margin-top:24px;flex-wrap:wrap;}
      .pv__body{margin-top:34px;font-size:17px;color:#222;}
      .pv__body h2{font-weight:700;font-size:24px;margin:34px 0 12px;} .pv__body img{width:100%;border-radius:12px;margin:14px 0 22px;display:block;} .pv__body p{margin:0 0 18px;} .pv__body pre{background:#0a0a0a;color:#e6e6e6;border-radius:10px;padding:16px;overflow:auto;font:13px/1.6 var(--mono);} .pv__body em{color:var(--accent);font-style:italic;}
    </style>
  </head>
  <body>
    <section id="login" class="login wrap hidden">
      <div class="login__kicker">Console</div>
      <h1>Welcome back.</h1>
      <form id="login-form"><input id="password" type="password" placeholder="Password" autocomplete="current-password" /><button class="btn" type="submit">Enter</button></form>
      <div id="login-msg" class="msg"></div>
    </section>

    <section id="list" class="wrap hidden">
      <div class="head">
        <h1>Projects</h1>
        <div class="tools"><button id="logout" class="logout">Log out</button></div>
      </div>
      <p class="lead">Reorder, edit metadata, or remove entries. New projects are authored as code (the <code>/showcase</code> skill) — the body is never edited here.</p>
      <div id="list-rows" class="rows"></div>
      <div class="deploybar"><span id="deploy-msg" class="msg"></span><button id="deploy" class="btn" disabled>Deploy</button></div>
    </section>

    <section id="editor" class="panel wrap hidden">
      <div class="panel__head"><h1 id="editor-title">New project</h1><button id="editor-cancel" class="logout">← Back</button></div>
      <div class="field">
        <label>Thumbnail *</label>
        <label class="drop"><img id="f-thumb-preview" alt="" /><span id="f-thumb-label" class="dim">Click to upload an image</span><input id="f-thumb" type="file" accept="image/*" class="hidden" /></label>
      </div>
      <div class="grid2">
        <div class="field"><label>Title *</label><input id="f-title" type="text" /></div>
        <div class="field"><label>Slug (URL)</label><input id="f-slug" type="text" placeholder="auto from title" /></div>
      </div>
      <div class="field"><label>Tagline * (one line)</label><input id="f-tagline" type="text" /></div>
      <div class="grid2">
        <div class="field">
          <label>Types * (Enter or comma to add)</label>
          <div id="f-types" class="tags"></div>
          <input id="f-type-input" type="text" placeholder="e.g. Websites, AI…" list="type-suggest" autocomplete="off" />
          <datalist id="type-suggest"></datalist>
        </div>
        <div class="field"><label>Year *</label><input id="f-year" type="number" /></div>
      </div>
      <div class="grid2">
        <div class="field"><label>Team size</label><input id="f-team" type="number" value="1" /></div>
        <div class="field"><label>Role</label><input id="f-role" type="text" placeholder="Product · Frontend" /></div>
      </div>
      <div class="field"><label>Stack (comma separated)</label><input id="f-stack" type="text" placeholder="Next.js, Supabase" /></div>
      <div class="field"><label>GitHub URL</label><input id="f-repo" type="url" /></div>
      <div class="field">
        <label>Links (extra buttons — label + URL)</label>
        <div id="f-links"></div>
        <button type="button" id="add-link" class="btn btn--sm btn--ghost" style="margin-top:4px">＋ Add link</button>
      </div>
      <p class="dim" style="font-size:13px;margin:4px 0 0;">Body is edited in code, not here — it's preserved untouched on save.</p>
      <div class="actions"><button id="editor-save" class="btn">Save</button><button id="editor-preview" class="btn btn--ghost">Preview</button><span id="editor-msg" class="msg"></span></div>
    </section>

    <section id="preview" class="pv wrap hidden">
      <div class="panel__head"><h1>Preview</h1><button id="preview-back" class="logout">← Back to editor</button></div>
      <div class="pv__card"><div class="pv__media"><img id="pv-img" alt="" /></div><div class="pv__cap"><b id="pv-title"></b> – <span id="pv-tagline"></span></div><div class="pv__meta" id="pv-meta"></div></div>
      <div class="pv__hr"></div>
      <div class="pv__kicker" id="pv-kicker"></div><div class="pv__title" id="pv-title2"></div><div class="pv__tag" id="pv-tagline2"></div>
      <div class="pv__btns" id="pv-btns"></div>
    </section>

    <script>
      // the site's signature ink cursor — builds its own DOM, desktop-only, reduced-motion aware
      import { initCursor } from '../../lib/cursor';
      initCursor();
    </script>

    <script is:inline define:vars={{ REPO: site.repo, SITE: 'https://' + site.domain }}>
      const $ = (id) => document.getElementById(id);
      // Load committed assets from the LIVE site, not raw.githubusercontent.com:
      // raw 404s for a private repo, whereas Cloudflare serves the built public/ at the root.
      const RAW = SITE;
      const VIEWS = ['login', 'list', 'editor', 'preview'];
      const view = (v) => VIEWS.forEach((x) => $(x).classList.toggle('hidden', x !== v));
      const titleCase = (s) => String(s || '').trim().replace(/\s+/g, ' ').toLowerCase().replace(/\b\w/g, (c) => c.toUpperCase());
      const esc = (s) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

      // body is intentionally absent — the console never edits it, so it's not part of dirty comparison
      const FIELDS = ['title', 'tagline', 'types', 'thumbnail', 'role', 'team', 'year', 'stack', 'repo', 'links', 'order'];
      const serialize = (p) => JSON.stringify(FIELDS.map((f) => (f === 'stack' ? (p.stack || []).join('|') : f === 'types' ? (p.types || []).join('|') : f === 'links' ? JSON.stringify(p.links || []) : p[f] ?? '')));

      let original = new Map();
      let working = [];
      let deletes = [];
      let editingSlug = null;
      let pendingThumb = null;
      let typeTags = []; // multi-tag types for the project being edited

      const thumbSrc = (p) => (p._thumb ? p._thumb.dataUrl : p.thumbnail ? RAW + p.thumbnail : '');
      // console edits metadata + order only; a new thumbnail or any meta change marks dirty
      const isDirty = (p, i) => p._thumb || serialize({ ...p, order: i }) !== original.get(p.slug);

      async function boot() {
        let authed = false;
        try { authed = (await (await fetch('/api/me')).json()).authed; } catch {}
        if (authed) { await loadList(); view('list'); } else view('login');
      }

      $('login-form').onsubmit = async (e) => {
        e.preventDefault(); const msg = $('login-msg'); msg.textContent = '';
        const r = await fetch('/api/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ password: $('password').value }) });
        if (r.ok) { await loadList(); view('list'); } else { const d = await r.json().catch(() => ({})); msg.textContent = d.error || 'Login failed.'; }
      };
      $('logout').onclick = async () => { await fetch('/api/logout', { method: 'POST' }); location.reload(); };

      async function loadList() {
        const r = await fetch('/api/projects');
        if (!r.ok) { $('deploy-msg').textContent = 'Could not load projects.'; return; }
        const { projects } = await r.json();
        // normalize order to the list index, so a freshly loaded list is never "dirty"
        // just because a file's stored order value differs from its position (e.g. order:100
        // sitting at index 0). order is owned by list position; deploy writes index → order.
        working = projects.map((p, i) => ({ ...p, stack: p.stack || [], links: p.links || [], types: p.types || [], order: i }));
        original = new Map(working.map((p) => [p.slug, serialize(p)]));
        deletes = [];
        renderList();
      }
      function pendingCount() { return deletes.length + working.filter((p, i) => isDirty(p, i)).length; }
      function renderList() {
        const rows = working.map((p, i) => {
          const ch = isDirty(p, i);
          const chips = (p.types || []).map((t) => `<span class="row__chip">${esc(t)}</span>`).join('') || '<span class="row__chip">—</span>';
          return `<div class="row ${ch ? 'pending' : ''}"><div class="row__thumb"><img src="${esc(thumbSrc(p))}" alt="" onerror="this.style.opacity=0" /></div><div><div class="row__title">${esc(p.title)}</div><div class="row__meta">${chips}<span class="row__sub">${esc(p.year)}</span>${ch ? '<span class="row__sub is-pending">● pending</span>' : ''}</div></div><div class="row__acts"><button class="iconbtn" data-act="up" data-i="${i}" ${i === 0 ? 'disabled' : ''} aria-label="Move up">↑</button><button class="iconbtn" data-act="down" data-i="${i}" ${i === working.length - 1 ? 'disabled' : ''} aria-label="Move down">↓</button><button class="iconbtn iconbtn--text" data-act="edit" data-i="${i}">Edit</button><button class="iconbtn del" data-act="del" data-i="${i}" aria-label="Delete">✕</button></div></div>`;
        });
        $('list-rows').innerHTML = rows.join('') || '<p class="dim">No projects yet. Add your first one →</p>';
        const n = pendingCount();
        $('deploy').textContent = n ? `Deploy · ${n}` : 'Deploy';
        $('deploy').disabled = n === 0;
      }
      $('list-rows').onclick = (e) => {
        const btn = e.target.closest('.iconbtn'); if (!btn) return;
        const i = +btn.dataset.i, act = btn.dataset.act;
        if (act === 'up' && i > 0) { [working[i - 1], working[i]] = [working[i], working[i - 1]]; renderList(); }
        else if (act === 'down' && i < working.length - 1) { [working[i + 1], working[i]] = [working[i], working[i + 1]]; renderList(); }
        else if (act === 'edit') openEditor(working[i]);
        else if (act === 'del') { const p = working[i]; deletes.push({ slug: p.slug, thumbnail: p.thumbnail, ext: p.ext }); working.splice(i, 1); renderList(); }
      };

      // ---- editor (metadata only; always editing an existing entry) ----
      $('editor-cancel').onclick = () => view('list');
      $('add-link').onclick = () => addLinkRow('', '');

      function addLinkRow(label, url) {
        const div = document.createElement('div');
        div.className = 'linkrow';
        div.innerHTML = `<input class="lk-label" type="text" placeholder="Label (e.g. Live demo)" /><input class="lk-url" type="url" placeholder="https://..." /><button type="button" class="iconbtn rm">✕</button>`;
        div.querySelector('.lk-label').value = label || '';
        div.querySelector('.lk-url').value = url || '';
        div.querySelector('.rm').onclick = () => div.remove();
        $('f-links').appendChild(div);
      }
      const readLinks = () => [...$('f-links').querySelectorAll('.linkrow')].map((r) => ({ label: r.querySelector('.lk-label').value.trim(), url: r.querySelector('.lk-url').value.trim() })).filter((l) => l.label && l.url);

      // ---- type tags (multi, Title Case, deduped) ----
      function renderTypeTags() {
        $('f-types').innerHTML = typeTags.map((t, i) => `<span class="tag">${esc(t)}<button type="button" class="tag__x" data-i="${i}">✕</button></span>`).join('');
      }
      function addType(raw) {
        const v = titleCase(raw);
        if (!v || typeTags.some((t) => t.toLowerCase() === v.toLowerCase())) return;
        typeTags.push(v); renderTypeTags();
      }
      function refreshTypeSuggest() {
        const all = [...new Set(working.flatMap((p) => p.types || []))].sort();
        $('type-suggest').innerHTML = all.map((t) => `<option value="${esc(t)}"></option>`).join('');
      }
      $('f-types').onclick = (e) => { const b = e.target.closest('.tag__x'); if (!b) return; typeTags.splice(+b.dataset.i, 1); renderTypeTags(); };
      $('f-type-input').addEventListener('keydown', (e) => {
        const ti = e.currentTarget;
        if (e.key === 'Enter' || e.key === ',') { e.preventDefault(); addType(ti.value); ti.value = ''; }
        else if (e.key === 'Backspace' && !ti.value && typeTags.length) { typeTags.pop(); renderTypeTags(); }
      });
      $('f-type-input').addEventListener('blur', (e) => { if (e.target.value.trim()) { addType(e.target.value); e.target.value = ''; } });

      function openEditor(p) {
        editingSlug = p.slug;
        pendingThumb = null;
        $('editor-msg').textContent = '';
        $('f-title').value = p.title || '';
        $('f-slug').value = p.slug || ''; $('f-slug').disabled = true; // slug is fixed (it's the filename)
        $('f-tagline').value = p.tagline || '';
        typeTags = (p.types || []).slice(); renderTypeTags(); refreshTypeSuggest(); $('f-type-input').value = '';
        $('f-year').value = p.year || '';
        $('f-team').value = p.team || 1;
        $('f-role').value = p.role || '';
        $('f-stack').value = (p.stack || []).join(', ');
        $('f-repo').value = p.repo || '';
        $('f-links').innerHTML = '';
        (p.links || []).forEach((l) => addLinkRow(l.label, l.url));
        $('f-thumb-preview').src = thumbSrc(p) || '';
        $('f-thumb-label').textContent = p.thumbnail ? p.thumbnail.split('/').pop() : 'Click to upload an image';
        view('editor');
      }

      $('f-thumb').onchange = (e) => {
        const file = e.target.files[0]; if (!file) return;
        const reader = new FileReader();
        reader.onload = () => { pendingThumb = { name: file.name, data: String(reader.result).split(',')[1], dataUrl: reader.result }; $('f-thumb-preview').src = reader.result; $('f-thumb-label').textContent = file.name; };
        reader.readAsDataURL(file);
      };

      function readForm() {
        return { title: $('f-title').value.trim(), tagline: $('f-tagline').value.trim(), types: typeTags.slice(), year: Number($('f-year').value), team: Number($('f-team').value) || 1, role: $('f-role').value.trim(), stack: $('f-stack').value.split(',').map((s) => s.trim()).filter(Boolean), repo: $('f-repo').value.trim(), links: readLinks() };
      }

      $('editor-save').onclick = () => {
        const d = readForm();
        if (!d.title || !d.tagline || !d.types.length || !d.year) { $('editor-msg').textContent = 'Fill all required (*) fields, including at least one type.'; return; }
        const p = working.find((x) => x.slug === editingSlug);
        if (!p) { $('editor-msg').textContent = 'Entry not found.'; return; }
        Object.assign(p, d); // metadata only — body & ext stay untouched
        if (pendingThumb) p._thumb = pendingThumb;
        view('list'); renderList();
      };

      // ---- preview (card + header meta only; body is authored as code, not shown here) ----
      $('editor-preview').onclick = () => {
        const d = readForm();
        const img = pendingThumb ? pendingThumb.dataUrl : thumbSrc(working.find((p) => p.slug === editingSlug) || {});
        $('pv-img').src = img || '';
        $('pv-title').textContent = d.title || 'Untitled'; $('pv-tagline').textContent = d.tagline || '';
        const team = d.team > 1 ? `Team of ${d.team}` : 'Solo';
        const typeStr = d.types.join(' · ') || '—';
        $('pv-meta').textContent = `${typeStr} · ${d.year}`;
        $('pv-kicker').textContent = `${typeStr} · ${d.year} · ${team}`;
        $('pv-title2').textContent = d.title || 'Untitled'; $('pv-tagline2').textContent = d.tagline || '';
        $('pv-btns').innerHTML = (d.repo ? `<span class="btn btn--sm">View on GitHub ↗</span>` : '') + d.links.map((l) => `<span class="btn btn--sm btn--ghost">${esc(l.label)} ↗</span>`).join('');
        view('preview');
      };
      $('preview-back').onclick = () => view('editor');

      // ---- deploy ----
      $('deploy').onclick = async () => {
        const upserts = [];
        working.forEach((p, i) => {
          if (isDirty(p, i)) upserts.push({ slug: p.slug, ext: p.ext, title: p.title, tagline: p.tagline, types: p.types || [], year: p.year, team: p.team, role: p.role, stack: p.stack, repo: p.repo, links: p.links || [], order: i, body: p.body, thumbnail: p.thumbnail, thumbnailName: p._thumb?.name, thumbnailData: p._thumb?.data });
        });
        const n = upserts.length + deletes.length;
        if (!n) return;
        if (!confirm(`Deploy ${n} change${n === 1 ? '' : 's'} to the live site?\nThis commits to the repo and rebuilds github.jsyoo.dev (~1 min).`)) return;
        const msg = $('deploy-msg'); msg.classList.remove('ok');
        $('deploy').disabled = true; msg.textContent = 'Deploying…';
        try {
          const r = await fetch('/api/deploy', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ upserts, deletes }) });
          const data = await r.json();
          if (r.ok) { msg.classList.add('ok'); msg.textContent = 'Deployed. Site rebuilds in ~1 min.'; await loadList(); }
          else { msg.textContent = data.error || 'Deploy failed.'; $('deploy').disabled = false; }
        } catch { msg.textContent = 'Network error.'; $('deploy').disabled = false; }
      };

      boot();
    </script>
  </body>
</html>
