---
import Roll from './Roll.astro';
import { site } from '../config/site';
// Black footer. Left = brand + tagline + About button. Right = socials.
// All identity/links live in src/config/site.ts — edit there.
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer__inner">
    <div class="footer__left">
      <a class="footer__portfolio" href={site.portfolioUrl} target="_blank" rel="noopener">About ↗</a>
      <div class="footer__brand">{site.brand}</div>
      <p class="footer__tag">{site.footerTagline}</p>
    </div>
    <nav class="footer__socials">
      {site.socials.map((s) => (
        s.mail
          ? <a data-mail-user={s.mail[0]} data-mail-domain={s.mail[1]}><Roll text={s.label} /></a>
          : <a href={s.href} target="_blank" rel="noopener"><Roll text={s.label} /></a>
      ))}
    </nav>
    <div class="footer__copy">
      <span>© {year} {site.brand}</span>
      <span>{site.domain}</span>
    </div>
  </div>
</footer>
