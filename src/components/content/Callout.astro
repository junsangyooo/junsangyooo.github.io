---
// Emphasis box for a key insight or caveat. Use inside .mdx project bodies.
// Renders a block-level root, so the detail-page reveal fades it up automatically.
interface Props {
  title?: string;
  tone?: 'note' | 'warn';
}
const { title, tone = 'note' } = Astro.props;
---

<aside class={`callout callout--${tone}`}>
  {title && <p class="callout__title">{title}</p>}
  <div class="callout__body"><slot /></div>
</aside>

<style>
  .callout {
    border-left: 3px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    border-radius: 10px; padding: 16px 18px; margin: 26px 0;
  }
  .callout--warn { border-color: #c0392b; background: color-mix(in srgb, #c0392b 5%, transparent); }
  .callout__title { font: 600 14px/1.3 var(--font); margin: 0 0 6px; letter-spacing: -0.01em; }
  .callout__body :global(p) { margin: 0; font-size: 16px; line-height: 1.6; color: #333; }
  .callout__body :global(p + p) { margin-top: 10px; }
</style>
