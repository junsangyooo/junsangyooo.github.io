---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'Junsang Yoo — Projects', description = 'Selected GitHub projects — what, why, and how.' } = Astro.props;
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      // run before paint: never restore prior scroll, always start at the top
      history.scrollRestoration = 'manual';
      window.scrollTo(0, 0);
      document.documentElement.classList.remove('no-js');
      // Failsafe: if the effects bundle never boots, don't leave reveal targets
      // hidden forever. After load-phase animations would have run, drop the
      // CSS pre-hide; GSAP-controlled (scroll) elements keep their inline hide.
      setTimeout(function () {
        document.documentElement.classList.add('anim-failsafe');
      }, 4000);
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      import '../scripts/main.ts';
    </script>
  </body>
</html>
