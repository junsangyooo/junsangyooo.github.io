---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Roll from '../components/Roll.astro';
import { site } from '../config/site';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// Filter tabs are derived from the categories actually present in content.
const CATEGORY_ORDER = ['Websites', 'Applications', 'Tools'];
const categories = CATEGORY_ORDER.filter((c) =>
  projects.some((p) => p.data.category === c)
);

// Split into two columns; the right column is staggered down (zigzag).
const left = projects.filter((_, i) => i % 2 === 0);
const right = projects.filter((_, i) => i % 2 === 1);
const isEmpty = projects.length === 0;
---

<Base title="Junsang Yoo — Projects" description="Selected GitHub projects — what, why, and how.">
  <header class="intro wrap">
    <h1 data-intro>{site.intro.title}</h1>
    <p data-intro>{site.intro.subtitle}</p>
    {!isEmpty && (
      <nav class="filters" data-intro>
        <button class="active" data-filter="all"><Roll text="All Projects" /></button>
        {categories.map((c) => <button data-filter={c}><Roll text={c} /></button>)}
      </nav>
    )}
  </header>

  {isEmpty ? (
    <section class="empty wrap">
      <p data-intro>No projects here yet — the first commits are on their way.</p>
    </section>
  ) : (
    <section class="list wrap">
      <div class="list__col">
        {left.map((p) => <ProjectCard project={p} />)}
      </div>
      <div class="list__col list__col--right">
        {right.map((p) => <ProjectCard project={p} />)}
      </div>
    </section>
  )}
</Base>

<style>
  .empty { padding: clamp(40px, 8vw, 90px) 0 clamp(60px, 10vw, 120px); }
  .empty p { color: var(--soft); font-size: clamp(18px, 2vw, 24px); letter-spacing: -0.01em; }
</style>
