---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import Roll from '../components/Roll.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const d = project.data;
const { Content } = await render(project);
const teamLabel = d.team > 1 ? `Team of ${d.team}` : 'Solo';
const kicker = [...d.types, String(d.year), teamLabel].join(' · ');
---

<Base title={`${d.title} — Junsang Yoo`} description={d.tagline}>
  <article class="detail wrap">
    <a class="detail__back" href="/" data-rise><Roll text="← All Projects" /></a>

    <div class="detail__kicker mono" data-rise>{kicker}</div>
    <h1 class="detail__title disp" data-rise>{d.title}</h1>
    <p class="detail__tagline" data-rise>{d.tagline}</p>

    <div class="detail__links" data-rise>
      {d.repo && <a class="btn btn--solid" href={d.repo} target="_blank" rel="noopener">View on GitHub ↗</a>}
      {d.links.map((l) => <a class="btn" href={l.url} target="_blank" rel="noopener">{l.label} ↗</a>)}
    </div>

    <div class="detail__media" data-rise>
      <img src={d.thumbnail} alt={d.title} onerror="this.style.opacity=0" />
    </div>

    <dl class="detail__facts" data-rise>
      <div><dt>Role</dt><dd>{d.role ?? '—'}</dd></div>
      <div><dt>Team</dt><dd>{teamLabel}</dd></div>
      <div><dt>Year</dt><dd>{d.year}</dd></div>
      <div><dt>Stack</dt><dd>{d.stack.join(' · ') || '—'}</dd></div>
    </dl>

    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .detail { max-width: 820px; padding-top: clamp(60px, 10vh, 120px); padding-bottom: 100px; }
  .detail__back { font: 500 13px/1 var(--mono); color: var(--soft); }
  .detail__back:hover { color: var(--fg); }
  .detail__kicker { margin-top: 48px; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--soft); }
  .detail__title { font-weight: 600; letter-spacing: -0.035em; line-height: 0.95; font-size: clamp(44px, 7vw, 92px); margin-top: 14px; }
  .detail__tagline { font-family: var(--font); font-weight: 500; font-size: clamp(18px, 2.4vw, 26px); margin-top: 16px; max-width: 36ch; letter-spacing: -0.01em; }
  .detail__links { display: flex; gap: 12px; margin-top: 30px; }
  /* .btn / .btn--solid are shared from global.css (convex-fill, matches the footer About button) */
  .detail__media { position: relative; aspect-ratio: 16 / 9; border-radius: 18px; overflow: hidden; background: var(--line); margin: 44px 0; }
  .detail__media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .detail__facts { display: grid; grid-template-columns: repeat(4, 1fr); border: 1px solid var(--line); border-radius: 14px; overflow: hidden; margin-bottom: 50px; }
  .detail__facts > div { padding: 18px; border-right: 1px solid var(--line); }
  .detail__facts > div:last-child { border-right: 0; }
  .detail__facts dt { font: 500 10px/1 var(--mono); letter-spacing: 0.12em; text-transform: uppercase; color: var(--soft); }
  .detail__facts dd { margin-top: 10px; font: 600 14px/1.4 var(--font); }
  .prose :global(h2) { font-family: var(--font); font-weight: 700; font-size: clamp(22px, 3vw, 30px); margin: 40px 0 14px; letter-spacing: -0.02em; }
  .prose :global(p) { font-size: 18px; color: #222; margin-bottom: 20px; }
  .prose :global(img) { display: block; width: 100%; border-radius: 14px; margin: 14px 0 26px; }
  .prose :global(em) { font-style: italic; }
  .prose :global(pre) { background: #0a0a0a; color: #e6e6e6; border-radius: 12px; padding: 20px; overflow: auto; font: 13px/1.6 var(--mono); margin-bottom: 20px; }
  .prose :global(code) { font-family: var(--mono); }
  /* full body vocabulary (the global reset zeroes list padding, so restore it here) */
  .prose :global(h3) { font-family: var(--font); font-weight: 700; font-size: clamp(18px, 2.2vw, 22px); margin: 30px 0 10px; letter-spacing: -0.015em; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 20px; padding-left: 1.3em; }
  .prose :global(li) { font-size: 18px; line-height: 1.6; color: #222; margin-bottom: 8px; }
  .prose :global(li)::marker { color: var(--soft); }
  .prose :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(blockquote) { margin: 24px 0; padding-left: 18px; border-left: 3px solid var(--line); color: var(--soft); font-style: italic; }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 40px 0; }
  @media (max-width: 600px) { .detail__facts { grid-template-columns: repeat(2, 1fr); } }
</style>
