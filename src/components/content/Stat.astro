---
// A row of outcome metrics. items = [{ value: "3×", label: "faster" }, ...]
interface Props {
  items: { value: string; label: string }[];
}
const { items = [] } = Astro.props;
---

<dl class="stat">
  {items.map((it) => (
    <div class="stat__cell"><dt>{it.value}</dt><dd>{it.label}</dd></div>
  ))}
</dl>

<style>
  .stat {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 1px;
    background: var(--line); border: 1px solid var(--line); border-radius: 14px;
    overflow: hidden; margin: 30px 0;
  }
  .stat__cell { background: var(--bg); padding: 20px 18px; }
  .stat dt { font: 600 clamp(26px, 4vw, 38px)/1 var(--font); letter-spacing: -0.03em; }
  .stat dd { font: 500 11px/1.3 var(--mono); text-transform: uppercase; letter-spacing: 0.08em; color: var(--soft); margin: 8px 0 0; }
</style>
